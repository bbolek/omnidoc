[Desktop Entry]
Categories={{categories}}
{{#if comment}}
Comment={{comment}}
{{/if}}
Exec={{exec}} %F
Icon={{icon}}
Name={{name}}
Terminal=false
Type=Application
{{#if mime_type}}
MimeType={{mime_type}};inode/directory;
{{/if}}
Actions=open-folder;

[Desktop Action open-folder]
Name=Open with Omnidoc
Exec={{exec}} %f
